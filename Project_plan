  public function createBooking(array $data): Booking
  {
      return DB::transaction(function () use ($data) {
          // 1. Lock the room row
          $room = Room::where('id', $data['room_id'])
              ->lockForUpdate()
              ->firstOrFail();

          // 2. Check for overlapping bookings
          $overlap = Booking::where('room_id', $room->id)
              ->where('status', '!=', 'cancelled')
              ->where(function ($q) use ($data) {
                  $q->where('check_in_date', '<', $data['check_out_date'])
                    ->where('check_out_date', '>', $data['check_in_date']);
              })->exists();

          if ($overlap) {
              throw new BookingConflictException('Room is not available for the selected dates.');
          }

          // 3. Calculate pricing
          $pricing = $this->pricingEngine->calculate(
              $room->roomType,
              $data['check_in_date'],
              $data['check_out_date']
          );

          // 4. Create guest if new
          // 5. Create booking record
          // 6. Create addons if any
          // 7. Update room status if check-in is today
          // 8. Return booking
      });
  }
  ```
