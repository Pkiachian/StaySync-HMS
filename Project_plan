  // In BookingService or FolioService
  public function getFolioSummary(Booking $booking): array
  {
      $roomCharges = $booking->folioCharges->where('charge_type', 'room')->sum('amount');
      $otherCharges = $booking->folioCharges->where('charge_type', '!=', 'room')->sum('amount');
      $totalCharges = $booking->folioCharges->sum('amount');
      $totalPayments = $booking->payments->where('status', 'completed')->sum('amount');
      $balance = $totalCharges - $totalPayments;

